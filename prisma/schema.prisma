generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String         @id @default(cuid())
  name           String         @default("Jhullya Isabela")
  goalType       GoalType       @default(MAINTAIN)
  targetWeight   Float?
  weeklyPace     Float?
  targetDate     DateTime?
  dailyWaterGoal Int            @default(8)
  focus          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  checkIns       DailyCheckIn[]
}

model Food {
  id          String   @id @default(cuid())
  name        String
  category    FoodCategory @default(OTHER)
  porcao      String // "200g", "1 prato"
  kcalPorcao  Int
  proteina    Float?
  carboidrato Float?
  gordura     Float?
  fotoUrl     String?
  createdAt   DateTime @default(now())
  favoritos   Boolean  @default(false)
}

model DailyLog {
  id        String    @id @default(cuid())
  date      DateTime
  dateKey   String    @unique
  meta      Int       @default(2500)
  consumido Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  items     LogItem[]
}

model LogItem {
  id          String
  foodId      String
  dailyLogId  String
  quantidade  Float    @default(1.0)
  refeicao    Refeicao
  name        String
  porcao      String
  kcalPorcao  Int
  proteina    Float    @default(0)
  carboidrato Float    @default(0)
  gordura     Float    @default(0)
  createdAt   DateTime @default(now())

  dailyLog DailyLog @relation(fields: [dailyLogId], references: [id], onDelete: Cascade)

  @@id([id, dailyLogId])
  @@index([dailyLogId])
}

model WeeklyGoal {
  id        String   @id @default(cuid())
  weekKey   String   @unique
  kcal      Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WeightEntry {
  id        String   @id @default(cuid())
  dateKey   String   @unique
  weight    Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AppSetting {
  key       String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DailyCheckIn {
  id           String   @id @default(cuid())
  dateKey      String   @unique
  mood         Int      @default(3)
  energy       Int      @default(3)
  hunger       Int      @default(3)
  waterGlasses Int      @default(0)
  sleepHours   Float    @default(0)
  note         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  userId       String?

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

enum Refeicao {
  BREAKFAST
  LUNCH
  DINNER
  SNACKS
}

enum GoalType {
  CUT
  GAIN
  MAINTAIN
}

enum FoodCategory {
  PROTEIN
  CARB
  FRUIT
  VEGETABLE
  DAIRY
  DRINK
  SNACK
  SWEET
  OTHER
}
